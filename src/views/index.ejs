<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>

    <body>
        <%- include('./partials/nav.ejs') %>
            <div id="card-container">
                <% messages.forEach(message=> { %>
                    <div class="card">
                        <p>
                            <%=message.user%>
                        </p>
                        <p>
                            <%=message.text%>
                        </p>
                        <p>
                            <%=message.added%>
                        </p>
                        <div class="right-align">
                            <a href="/message/<%= message.id %>">Open</a>
                        </div>
                    </div>
                    <% }) %>
            </div>
    </body>

</html>